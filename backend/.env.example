# ─── Server ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development # production

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/clearpath
REDIS_URL=redis://localhost:6379

# ─── JWT / Token Settings ─────────────────────────────────
# Short access token lifetime (15m, 1h, etc.)
ACCESS_TOKEN_EXPIRY=15m
# Refresh token lifetime in full days
REFRESH_TOKEN_EXPIRY_DAYS=7

#supabase config
SUPABASE_URL=https://your-project.supabase.co

SUPABASE_PUBLISHABLE_KEY=sb_publishable_

SUPABASE_SECRET_KEY=sb_secret_


# ─── Database (raw pg pool) ───────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Use the "Session" pooler (port 5432) or "Transaction" pooler (port 6543).
# For the outbox dispatcher LISTEN/NOTIFY, use Session pooler (port 5432).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Pipeline ─────────────────────────────────────────────────────────────────
ANALYSIS_QUEUE_NAME=document-analysis
ANALYSIS_JOB_ATTEMPTS=5
ANALYSIS_VERSION=v1

# Worker identity - unique per process/container for multi-worker setups
WORKER_ID=worker-1

# Tesseract language packs (must be installed: apt-get install tesseract-ocr-eng tesseract-ocr-urd)
TESSERACT_LANGS=eng+urd
OCR_MIN_TEXT_CONFIDENCE=0.6

# @xenova/transformers model cache directory
TRANSFORMERS_CACHE=/var/cache/transformers

# ─── Outbox dispatcher ────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_MAX_RETRIES=10

# ─── SSE ──────────────────────────────────────────────────────────────────────
SSE_HEARTBEAT_INTERVAL_MS=15000

# ─── Internal endpoints ───────────────────────────────────────────────────────
INTERNAL_API_KEY=your-strong-random-internal-key
