{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "dev:simple": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "generate-keys": "node scripts/generate-keys.js",
    "supabase:migration": "supabase migration new",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:status": "supabase status",
    "worker": "tsx src/workers/run.ts",
    "dispatcher": "tsx src/outbox/run.ts",
    "dev:all": "concurrently -n API,WORKER,DISPATCHER -c blue,green,yellow \"npm:dev\" \"npm:worker\" \"npm:dispatcher\"",
    "start:all": "concurrently -n API,WORKER,DISPATCHER -c blue,green,yellow \"npm:start\" \"npm:worker\" \"npm:dispatcher\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.44.0",
    "bullmq": "^5.78.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pg": "^8.21.0",
    "sharp": "^0.35.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {}
}
